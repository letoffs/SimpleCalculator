<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовый стиль для всех кнопок -->
    <style name="CalculatorButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Стиль для цифровых кнопок -->
    <style name="NumberButton" parent="CalculatorButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">#333333</item>
    </style>

    <!-- Стиль для функциональных кнопок (C, AC, %, ⌫) -->
    <style name="FunctionButton" parent="CalculatorButton">
        <item name="android:textColor">#000000</item>
        <item name="android:background">#A5A5A5</item>
    </style>

    <!-- Стиль для кнопок операций (÷, ×, -, +) -->
    <style name="OperationButton" parent="CalculatorButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">#FF9F0A</item>
    </style>

    <!-- Стиль для кнопки равно -->
    <style name="EqualsButton" parent="CalculatorButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">#FF9F0A</item>
    </style>
</resources>